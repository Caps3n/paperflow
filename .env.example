# ── Paperless-NGX ──────────────────────────────────────────────
PAPERLESS_URL=http://localhost:8000
PAPERLESS_TOKEN=dein_api_token_hier

# ── Amazon ─────────────────────────────────────────────────────
AMAZON_EMAIL=deine@email.de
AMAZON_PASSWORD=dein_passwort
# Domain: amazon.de oder amazon.com
AMAZON_DOMAIN=amazon.de
# Wie viele Monate zurück scannen (default: 12)
AMAZON_MONTHS_BACK=12

# ── Allgemein ──────────────────────────────────────────────────
# Wie oft läuft der Fetcher (in Stunden)
RUN_INTERVAL_HOURS=24
# Beim Start sofort laufen (true/false)
RUN_ON_STARTUP=true
