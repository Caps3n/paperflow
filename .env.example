# ── Paperless-NGX ──────────────────────────────────────────────
PAPERLESS_URL=http://localhost:8000
PAPERLESS_TOKEN=your_api_token_here

# ── Amazon ─────────────────────────────────────────────────────
AMAZON_EMAIL=your@email.com
AMAZON_PASSWORD=your_password
# Domain: amazon.de or amazon.com
AMAZON_DOMAIN=amazon.de
# How many months back to scan (default: 12)
AMAZON_MONTHS_BACK=12

# ── IKEA ───────────────────────────────────────────────────────
IKEA_EMAIL=your@email.com
IKEA_PASSWORD=your_password
# How many months back to scan (default: 12)
IKEA_MONTHS_BACK=12

# ── Web UI Security ────────────────────────────────────────────
# Leave empty to disable authentication
UI_USER=admin
UI_PASSWORD=

# ── Scheduler ──────────────────────────────────────────────────
# How often to run (hours)
RUN_INTERVAL_HOURS=24
# Run immediately on startup (true/false)
RUN_ON_STARTUP=true
# Parallel upload threads
UPLOAD_WORKERS=3
